# ============================================================
# 家教在线平台 - 本地开发环境变量
# 复制为 .env 后按需修改
# ============================================================

# ---- MySQL ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=roncoo_education
MYSQL_USER=root
MYSQL_PASSWORD=RonCoo.123

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Nacos ----
NACOS_HOST=127.0.0.1
NACOS_PORT=8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
NACOS_NAMESPACE=dev

# ---- MinIO (对象存储) ----
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=education
MINIO_DOMAIN=http://127.0.0.1:9000/education/

# ---- JWT ----
JWT_TOKEN_SECRET=tutor-platform-dev-secret-key

# ---- Jasypt 加密密钥 (开发环境可明文) ----
JASYPT_PASSWORD=roncoo_education

# ---- XXL-JOB (可选，本地开发可跳过) ----
XXL_JOB_ADMIN_ADDRESSES=http://127.0.0.1:8088/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=roncoo_education
XXL_JOB_EXECUTOR_PORT=9901

# ---- 前端 ----
# 门户前端
WEB_PORT=3000
WEB_API_BASE=http://127.0.0.1:7700

# 管理后台
ADMIN_PORT=3100
ADMIN_API_BASE=http://127.0.0.1:7700

# ---- 后端服务端口 ----
GATEWAY_PORT=7700
SERVICE_SYSTEM_PORT=7710
SERVICE_USER_PORT=7720
SERVICE_COURSE_PORT=7730
